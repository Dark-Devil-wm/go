{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User account and profile information.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The unique ID of the user." },
        "displayName": { "type": "string", "description": "The user's display name." },
        "email": { "type": "string", "format": "email", "description": "The user's email address." },
        "avatar": { "type": "string", "description": "URL to the user's avatar image." },
        "role": { "type": "string", "enum": ["client", "admin", "trainer"], "description": "The user's role." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the profile was created." }
      },
      "required": ["userId", "email"]
    },
    "Trainer": {
      "title": "Trainer Profile",
      "description": "Details about a fitness trainer.",
      "type": "object",
      "properties": {
        "trainerId": { "type": "string" },
        "name": { "type": "string" },
        "specialization": { "type": "string" },
        "experience": { "type": "string" },
        "bio": { "type": "string" },
        "image": { "type": "string" },
        "certifications": { "type": "array", "items": { "type": "string" } },
        "social": {
          "type": "object",
          "properties": {
            "instagram": { "type": "string" },
            "facebook": { "type": "string" },
            "twitter": { "type": "string" },
            "linkedin": { "type": "string" }
          }
        },
        "rating": { "type": "number" },
        "active": { "type": "boolean" }
      },
      "required": ["name", "specialization", "image"]
    },
    "Program": {
      "title": "Fitness Program",
      "description": "A high-performance fitness program details.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "duration": { "type": "string" },
        "category": { "type": "string", "enum": ["Fat Loss", "Muscle Building", "Strength", "Conditioning"] },
        "price": { "type": "number" },
        "image": { "type": "string" }
      },
      "required": ["title", "category"]
    },
    "Booking": {
      "title": "Training Booking",
      "description": "A record of a scheduled personal training session.",
      "type": "object",
      "properties": {
        "bookingId": { "type": "string" },
        "userId": { "type": "string" },
        "trainerId": { "type": "string" },
        "serviceType": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "serviceType", "date"]
    },
    "BlogPost": {
      "title": "Blog Article",
      "description": "Premium fitness and nutrition articles.",
      "type": "object",
      "properties": {
        "articleId": { "type": "string" },
        "title": { "type": "string" },
        "excerpt": { "type": "string" },
        "content": { "type": "string" },
        "category": { "type": "string" },
        "author": { "type": "string" },
        "image": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "published": { "type": "boolean" }
      },
      "required": ["title", "content", "category"]
    },
    "Membership": {
      "title": "Membership Tier",
      "description": "Details of different membership tiers.",
      "type": "object",
      "properties": {
        "tierId": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "period": { "type": "string" },
        "features": { "type": "array", "items": { "type": "string" } },
        "color": { "type": "string" }
      },
      "required": ["name", "price", "features"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Stores user profiles."
    },
    "/programs/{programId}": {
      "schema": "Program",
      "description": "Stores available fitness programs."
    },
    "/trainers/{trainerId}": {
      "schema": "Trainer",
      "description": "Stores trainer profiles."
    },
    "/blog/{articleId}": {
      "schema": "BlogPost",
      "description": "Stores premium blog articles."
    },
    "/memberships/{tierId}": {
      "schema": "Membership",
      "description": "Stores membership tiers."
    },
    "/users/{userId}/bookings/{bookingId}": {
      "schema": "Booking",
      "description": "Stores user session bookings."
    }
  }
}
