rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // 3. Primitives
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isAdmin() { 
      // Hardcoded admin for initial setup or lookup in admins collection
      return isSignedIn() && (request.auth.token.email == 'muh.lahore90@gmail.com' && request.auth.token.email_verified == true);
    }
    
    function isTrainer() {
      // Check if user has trainer role in their profile
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'trainer';
    }

    // 2. Validation Helpers
    function isValidUser(data) {
      return data.userId is string && data.userId.size() <= 128 &&
             data.email is string && data.email.size() <= 128 &&
             (data.get('displayName', '') is string && data.get('displayName', '').size() <= 128) &&
             (data.get('role', 'client') in ['client', 'admin', 'trainer']);
    }

    function isValidTrainerProfile(data) {
      return data.name is string && data.name.size() <= 128 &&
             data.specialization is string &&
             data.image is string;
    }

    function isValidBooking(data) {
      return data.userId is string && data.userId.size() <= 128 &&
             data.serviceType is string && data.serviceType.size() <= 128 &&
             data.status in ['pending', 'confirmed', 'cancelled'];
    }

    function isValidBlogPost(data) {
      return data.title is string && data.title.size() <= 200 &&
             data.content is string && data.content.size() <= 50000 &&
             data.category is string &&
             data.published is bool;
    }

    function isValidMembership(data) {
      return data.name is string && data.name.size() <= 128 &&
             data.price is number &&
             data.features is list;
    }

    // MATCHES
    
    // Users Collection
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      
      allow create: if isOwner(userId) && 
                      isValidUser(incoming()) && 
                      incoming().userId == userId &&
                      incoming().role == 'client'; // Prevent self-elevation
                      
      allow update: if isOwner(userId) && 
                      isValidUser(incoming()) &&
                      incoming().role == existing().role && // Immortality of role for clients
                      incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'avatar']);
    }

    // Blog Collection
    match /blog/{articleId} {
      allow read: if true; // Public can see blog posts
      allow write: if isAdmin() || isTrainer();
    }

    // Trainers Collection
    match /trainers/{trainerId} {
      allow read: if true;
      allow write: if isAdmin() || (isTrainer() && request.auth.uid == trainerId);
    }

    // Memberships Collection
    match /memberships/{tierId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Programs Collection
    match /programs/{programId} {
      allow read: if true; // Public access to view programs
      allow write: if isAdmin();
    }

    // Bookings Subcollection
    match /users/{userId}/bookings/{bookingId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isOwner(userId) || isAdmin();
      
      allow create: if isOwner(userId) && 
                      isValidBooking(incoming()) &&
                      incoming().userId == userId &&
                      incoming().status == 'pending' &&
                      incoming().createdAt == request.time;
                      
      allow update: if (isOwner(userId) || isAdmin()) &&
                      isValidBooking(incoming()) &&
                      (
                        // Client can only cancel
                        (isOwner(userId) && incoming().status == 'cancelled' && 
                         incoming().diff(existing()).affectedKeys().hasOnly(['status'])) ||
                        // Admin can confirm
                        (isAdmin() && incoming().diff(existing()).affectedKeys().hasOnly(['status']))
                      );
    }

    // Applications Collection (Publicly writable for leads)
    match /applications/{applicationId} {
      allow create: if true;
      allow read, write: if isAdmin();
    }
  }
}
